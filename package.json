    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "fastify-plugin": "^4.5.1",
    "node-fetch": "^3.3.2",
    "nodemailer": "^9.0.1"
  },
