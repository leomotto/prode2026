// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// USERS
// ============================================================
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  displayName  String
  avatar       String   @default("⚽")
  googleId     String?  @unique
  passwordHash String?  // null si usa solo Google OAuth
  isAdmin      Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  predictions      Prediction[]
  sessions         UserSession[]
  ownedGroups      Group[]        @relation("GroupOwner")
  groupMemberships GroupMember[]
  groupMessages    GroupMessage[]
  helpRequests     HelpRequest[]

  @@map("users")
}

// Sesiones JWT invalidadas (logout)
model UserSession {
  id        String   @id @default(uuid())
  userId    String
  jwtToken  String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_sessions")
}

// ============================================================
// MATCHES
// ============================================================
enum MatchStatus {
  UPCOMING
  LIVE
  FINISHED
}

enum MatchPhase {
  GRUPOS
  DIECISEISAVOS
  OCTAVOS
  CUARTOS
  SEMIFINAL
  TERCER_PUESTO
  FINAL
}

model Match {
  id          String      @id // e.g. "ARG-ALG-GJ1"
  phase       MatchPhase
  groupName   String?     // "A"..."L" o null para eliminatorias
  teamAName   String
  teamAFlag   String
  teamACode   String
  teamBName   String
  teamBFlag   String
  teamBCode   String
  date        DateTime
  venue       String
  city        String
  status      MatchStatus @default(UPCOMING)
  resultA     Int?        // goles equipo A
  resultB     Int?        // goles equipo B
  featured    Boolean     @default(false) // destacado desde admin
  argentina   Boolean     @default(false) // partido de Argentina
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  predictions Prediction[]

  @@map("matches")
}

// ============================================================
// PREDICTIONS
// ============================================================
model Prediction {
  id           String    @id @default(uuid())
  userId       String
  matchId      String

  // Pronóstico principal
  scoreA       Int
  scoreB       Int

  // Bonus: predicciones especiales
  firstScorer  String?   // Nombre del primer goleador
  cardsCount   Int?      // Cantidad total de tarjetas
  cornersCount Int?      // Cantidad total de córners
  btts         Boolean?  // Both Teams To Score
  mvp          String?   // Jugador del partido

  // Puntuación calculada (null = no calculado aún)
  pointsBase   Int?      // puntos por resultado
  pointsBonus  Int?      // puntos bonus
  pointsTotal  Int?      // total

  locked       Boolean   @default(false) // bloqueado cuando match = LIVE
  calculatedAt DateTime?
  submittedAt  DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId])
  @@map("predictions")
}

// ============================================================
// PRIVATE GROUPS (Ligas entre amigos)
// ============================================================
model Group {
  id          String   @id @default(cuid())
  name        String   @db.VarChar(60)
  code        String   @unique // código 6 chars: "MESSI6"
  description String?  @db.VarChar(200)
  prizes      String?  // JSON string: {"1":"...","2":"...","3":"..."}
  ownerId     String
  maxMembers  Int      @default(50)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner    User           @relation("GroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members  GroupMember[]
  messages GroupMessage[]

  @@map("groups")
}

model GroupMember {
  groupId  String
  userId   String
  role     String   @default("MEMBER") // MEMBER, MANAGER
  joinedAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
  @@map("group_members")
}

model GroupMessage {
  id        String   @id @default(cuid())
  groupId   String
  userId    String
  content   String   @db.VarChar(500)
  createdAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("group_messages")
}

// ============================================================
// HELP REQUESTS
// ============================================================
model HelpRequest {
  id        String   @id @default(cuid())
  userId    String
  subject   String   @db.VarChar(100)
  message   String   @db.VarChar(1000)
  status    String   @default("OPEN") // OPEN, RESOLVED
  adminNote String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("help_requests")
}

