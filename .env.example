# Variables de entorno — Prode Mundial 2026
# Copiar como .env y completar con valores reales. NUNCA commitear .env

# === BASE DE DATOS (Alwaysdata PostgreSQL) ===
DATABASE_URL="postgresql://muchacholoco:TU_PASSWORD@postgresql-muchacholoco.alwaysdata.net:5432/muchacholoco_prode2026?schema=public"

# === SERVIDOR (Alwaysdata inyecta estas variables automáticamente) ===
PORT=8100
IP=0.0.0.0
NODE_ENV=production

# === JWT ===
JWT_SECRET="CAMBIAR_POR_32_CARACTERES_ALEATORIOS_MINIMO"

# === GOOGLE OAUTH2 ===
# Crear en https://console.cloud.google.com/ → APIs & Services → Credentials
GOOGLE_CLIENT_ID="TU_CLIENT_ID.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="TU_CLIENT_SECRET"
GOOGLE_CALLBACK_URL="https://prode.muchacholoco.com.ar/api/auth/google/callback"

# === CLOUDFLARE TURNSTILE ===
# Solo la SECRET_KEY es privada. La SITE_KEY es pública pero también va en .env
# para inyectarla server-side y no exponerla en el repositorio.
TURNSTILE_SECRET_KEY="TU_TURNSTILE_SECRET_KEY"
TURNSTILE_SITE_KEY="TU_TURNSTILE_SITE_KEY"

# === APP CONFIG ===
APP_URL="https://prode.muchacholoco.com.ar"
APP_NAME="Prode Mundial 2026"

# === ADMIN SETUP (usado solo al crear el primer admin) ===
ADMIN_SETUP_KEY="CAMBIAR_POR_CLAVE_SECRETA_ADMIN"

# === EMAIL / SMTP (para notificaciones de resultados) ===
# Usar Gmail (requiere App Password), Alwaysdata SMTP, o similar
# Si no se configura, los emails simplemente no se envían (no hay error)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="tu_email@gmail.com"
SMTP_PASS="tu_app_password_de_gmail"
SMTP_FROM="Prode 2026 <tu_email@gmail.com>"

